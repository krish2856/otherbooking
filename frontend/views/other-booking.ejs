<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>

<%- include('partials/navbar') %>

<div class="app-layout">
    <%- include('partials/sidebar') %>

    <main class="main-content">

        <!-- ===================== PAGE HEADER ===================== -->
        <div class="page-header d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div>
                <h4 class="page-title mb-0"><i class="bi bi-journal-plus text-accent me-2"></i>Other Booking</h4>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                        <li class="breadcrumb-item active">Other Booking</li>
                    </ol>
                </nav>
            </div>
            <div class="d-flex gap-2">
                <span class="badge-soft"><i class="bi bi-ticket-detailed me-1"></i>Next Ticket: <b id="nextTicketBadge"><%= nextTicketNo %></b></span>
            </div>
        </div>

        <!-- ===================== ALERT PLACEHOLDER ===================== -->
        <div id="alertBox" class="alert-floating"></div>

        <!-- ===================== BOOKING FORM CARD ===================== -->
        <div class="card app-card mb-4">
            <div class="card-header app-card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-pencil-square me-2"></i>Booking Form</span>
                <span class="text-muted small" id="formModeLabel">Mode: New Entry</span>
            </div>
            <div class="card-body">
                <form id="bookingForm" autocomplete="off">
                    <input type="hidden" id="bookingId" value="">

                    <!-- ===== Section: Journey Details ===== -->
                    <div class="form-section-title"><i class="bi bi-signpost-2 me-1"></i>Journey Details</div>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Booking Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="booking_date" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Journey Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="journey_date" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">From <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="from_place" placeholder="e.g. Ahmedabad" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">To <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="to_place" placeholder="e.g. Mumbai" required>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Operator <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="operator" placeholder="e.g. Shree Travels" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Coach</label>
                            <input type="text" class="form-control" id="coach" placeholder="e.g. A1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Journey Time</label>
                            <input type="time" class="form-control" id="journey_time">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Ticket Number</label>
                            <input type="text" class="form-control fw-bold text-accent" id="ticket_no" readonly>
                        </div>
                    </div>

                    <!-- ===== Section: Passenger Details ===== -->
                    <div class="form-section-title mt-4"><i class="bi bi-person-vcard me-1"></i>Passenger Details</div>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Passenger Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="passenger_name" placeholder="Full name" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Mobile Number <span class="text-danger">*</span></label>
                            <input type="tel" class="form-control" id="passenger_mobile" maxlength="10" placeholder="10-digit number" required>
                            <div class="form-text text-danger d-none" id="mobileError">Enter a valid 10-digit mobile number.</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Gender</label>
                            <select class="form-select" id="passenger_gender">
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Age</label>
                            <input type="number" class="form-control" id="passenger_age" min="1" max="120" placeholder="Age">
                        </div>
                    </div>

                    <!-- ===== Section: Seat & Pickup/Drop ===== -->
                    <div class="form-section-title mt-4"><i class="bi bi-grid-3x3-gap me-1"></i>Seat &amp; Boarding Details</div>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Seat Type</label>
                            <select class="form-select" id="seat_type">
                                <option value="Seater">Seater</option>
                                <option value="Sleeper">Sleeper</option>
                                <option value="Semi-Sleeper">Semi-Sleeper</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Seat Number <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="seat_number" placeholder="e.g. S-12" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Pickup Point</label>
                            <input type="text" class="form-control" id="pickup_point" placeholder="Pickup point">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Drop Point</label>
                            <input type="text" class="form-control" id="drop_point" placeholder="Drop point">
                        </div>
                    </div>

                    <!-- ===== Section: Fare & Payment ===== -->
                    <div class="form-section-title mt-4"><i class="bi bi-cash-stack me-1"></i>Fare &amp; Payment</div>
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label">Fare (₹) <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" min="0" class="form-control calc-field" id="fare" placeholder="0.00" required>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Discount (₹)</label>
                            <input type="number" step="0.01" min="0" class="form-control calc-field" id="discount" placeholder="0.00" value="0">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">GST (₹)</label>
                            <input type="number" step="0.01" min="0" class="form-control calc-field" id="gst" placeholder="0.00" value="0">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Net Amount (₹)</label>
                            <input type="number" step="0.01" class="form-control bg-light fw-bold" id="net_amount" readonly>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Paid Amount (₹)</label>
                            <input type="number" step="0.01" min="0" class="form-control calc-field" id="paid_amount" placeholder="0.00" value="0">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Due Amount (₹)</label>
                            <input type="number" step="0.01" class="form-control bg-light fw-bold text-danger" id="due_amount" readonly>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Payment Mode <span class="text-danger">*</span></label>
                            <select class="form-select" id="payment_mode" required>
                                <option value="Cash">Cash</option>
                                <option value="UPI">UPI</option>
                                <option value="Card">Card</option>
                                <option value="Online">Online</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">PNR</label>
                            <input type="text" class="form-control" id="pnr" placeholder="PNR number">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bus Number</label>
                            <input type="text" class="form-control" id="bus_number" placeholder="e.g. GJ-01-AB-1234">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Booking Status <span class="text-danger">*</span></label>
                            <select class="form-select" id="booking_status" required>
                                <option value="Confirmed">Confirmed</option>
                                <option value="Pending">Pending</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Remarks</label>
                            <textarea class="form-control" id="remarks" rows="2" placeholder="Any additional notes..."></textarea>
                        </div>
                    </div>

                    <!-- ===== Action Buttons ===== -->
                    <div class="form-actions mt-4 d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-secondary" id="btnNew"><i class="bi bi-file-earmark-plus me-1"></i>New</button>
                        <button type="submit" class="btn btn-accent" id="btnSave"><i class="bi bi-save me-1"></i>Save</button>
                        <button type="button" class="btn btn-warning text-white" id="btnUpdate"><i class="bi bi-arrow-repeat me-1"></i>Update</button>
                        <button type="button" class="btn btn-danger" id="btnDelete"><i class="bi bi-trash me-1"></i>Delete</button>
                        <button type="button" class="btn btn-outline-dark" id="btnClear"><i class="bi bi-eraser me-1"></i>Clear</button>
                        <div class="vr d-none d-md-block mx-1"></div>
                        <button type="button" class="btn btn-outline-primary" id="btnPrint"><i class="bi bi-printer me-1"></i>Print Ticket</button>
                        <button type="button" class="btn btn-outline-success" id="btnPdf"><i class="bi bi-file-earmark-pdf me-1"></i>Download PDF</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===================== SEARCH CARD ===================== -->
        <div class="card app-card mb-4">
            <div class="card-header app-card-header">
                <i class="bi bi-search me-2"></i>Search Bookings
            </div>
            <div class="card-body">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Search By</label>
                        <select class="form-select" id="searchField">
                            <option value="ticket_no">Ticket Number</option>
                            <option value="passenger_name">Passenger Name</option>
                            <option value="passenger_mobile">Phone Number</option>
                            <option value="pnr">PNR</option>
                            <option value="journey_date">Journey Date</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Keyword</label>
                        <input type="text" class="form-control" id="searchKeyword" placeholder="Enter search keyword...">
                        <input type="date" class="form-control d-none" id="searchKeywordDate">
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button class="btn btn-accent w-100" id="btnSearch"><i class="bi bi-search me-1"></i>Search</button>
                        <button class="btn btn-outline-secondary w-100" id="btnResetSearch"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== BOOKINGS TABLE ===================== -->
        <div class="card app-card mb-4">
            <div class="card-header app-card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-table me-2"></i>All Bookings</span>
                <span class="badge-soft" id="recordCount"><%= bookings.length %> records</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table app-table align-middle mb-0" id="bookingsTable">
                        <thead>
                            <tr>
                                <th>Ticket No</th>
                                <th>Journey Date</th>
                                <th>Passenger Name</th>
                                <th>Phone</th>
                                <th>From</th>
                                <th>To</th>
                                <th>Seat</th>
                                <th>Operator</th>
                                <th>Fare</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="bookingsTableBody">
                            <!-- Rows injected via EJS on load; refreshed via JS after that -->
                            <% if (bookings.length === 0) { %>
                                <tr id="emptyRow">
                                    <td colspan="11" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>No bookings found.
                                    </td>
                                </tr>
                            <% } %>
                            <% bookings.forEach(function(b) { %>
                                <tr data-id="<%= b.id %>">
                                    <td class="fw-semibold text-accent"><%= b.ticket_no %></td>
                                    <td><%= b.journey_date %></td>
                                    <td><%= b.passenger_name %></td>
                                    <td><%= b.passenger_mobile %></td>
                                    <td><%= b.from_place %></td>
                                    <td><%= b.to_place %></td>
                                    <td><%= b.seat_number %></td>
                                    <td><%= b.operator %></td>
                                    <td>₹<%= Number(b.fare).toFixed(2) %></td>
                                    <td>
                                        <span class="status-badge status-<%= b.booking_status.toLowerCase() %>"><%= b.booking_status %></span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-icon-table text-primary btn-edit-row" title="Edit"><i class="bi bi-pencil-square"></i></button>
                                        <button class="btn btn-sm btn-icon-table text-danger btn-delete-row" title="Delete"><i class="bi bi-trash"></i></button>
                                        <button class="btn btn-sm btn-icon-table text-success btn-print-row" title="Print"><i class="bi bi-printer"></i></button>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </main>
</div>

<!-- ===================== PRINT TICKET TEMPLATE (hidden, used for printing/PDF) ===================== -->
<div id="printArea" class="d-none"></div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- jsPDF + html2canvas for Download PDF -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<!-- Custom JS -->
<script src="/js/other-booking.js"></script>
</body>
</html>
